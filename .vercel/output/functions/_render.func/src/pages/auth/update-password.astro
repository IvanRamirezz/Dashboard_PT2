---
import AuthLayout from "../../layouts/AuthLayout.astro";
import Alert from "../../components/ui/Alert.astro";
import PasswordField from "../../components/ui/PasswordField.astro";
import { createSupabaseServerClient } from "../../lib/supabase";
import { getSessionCookieOptions } from "../../modules/auth/utils/sessionCookies";

const { url, cookies, redirect } = Astro;

const code = url.searchParams.get("code");

if (code) {
  const supabase = createSupabaseServerClient();
  const { data, error } = await supabase.auth.exchangeCodeForSession(code);

  if (error || !data.session) {
    return redirect("/auth/update-password?error=1");
  }

  cookies.set("sb-access-token", data.session.access_token, {
    ...getSessionCookieOptions(),
  });
  cookies.set("sb-refresh-token", data.session.refresh_token, {
    ...getSessionCookieOptions(),
  });

  return redirect("/auth/update-password");
}

const error = url.searchParams.get("error");
const success = url.searchParams.get("success");
---

<AuthLayout title="Nueva contraseña">

<h1 class="title">

{success ? "Contraseña actualizada" : "Nueva contraseña"}

</h1>

<p class="subtitle">

{success 
  ? "Tu contraseña se cambió correctamente. Ya puedes iniciar sesión."
  : "Escribe tu nueva contraseña."
}

</p>

<form
method="post"
action="/api/auth/update-password"
>

{
  success && (

    <Alert
      type="success"
      message="Contraseña actualizada correctamente"
    />

  )
}

{
  error && (

    <Alert
      type="error"
      message="Error al actualizar contraseña"
    />

  )
}


{!success && (

  <>
  
    <PasswordField
      label="Nueva contraseña"
      name="password"
    />

    <button class="btn">
      Actualizar contraseña
    </button>

  </>

)}

</form>

</AuthLayout>
