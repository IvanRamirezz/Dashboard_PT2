---
import ojo from "../../../../public/images/ojo.png";
import ojoOcultar from "../../../../public/images/ojo-ocultar.png";

interface Props {
  label?: string;
  name?: string;
  placeholder?: string;
  required?: boolean;
}

const {
  label       = "Contraseña",
  name        = "password",
  placeholder = "••••••••",
  required    = true,
} = Astro.props;

const inputId = `password-${Math.random().toString(36).slice(2)}`;
const btnId   = `btn-${inputId}`;
---

<div class="field">
  <label for={inputId}>{label}</label>

  <div class="password-container">
    <input
      id={inputId}
      name={name}
      type="password"
      placeholder={placeholder}
      required={required}
    />
    <button
      id={btnId}
      type="button"
      class="toggle-password"
      data-target={inputId}
      data-eye={ojo.src}
      data-eye-off={ojoOcultar.src}
    >
      <img src={ojo.src} alt="Mostrar contraseña" />
    </button>
  </div>
</div>

<script is:inline define:vars={{ btnId }}>
  const btn = document.getElementById(btnId);
  if (!btn) return;

  btn.addEventListener("click", () => {
    const inputId = btn.dataset.target;
    const input   = document.getElementById(inputId);
    const icon    = btn.querySelector("img");

    if (!input || !icon) return;

    const isHidden = input.type === "password";
    input.type     = isHidden ? "text" : "password";
    icon.src       = isHidden ? btn.dataset.eyeOff : btn.dataset.eye;
  });
</script>