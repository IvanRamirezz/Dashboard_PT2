---
// src/presentation/components/ui/Toast.astro
interface Props {
  message: string;
  type?: "success" | "error" | "info" | "warning";
  duration?: number;
}

const {
  message,
  type     = "success",
  duration = 3000,
} = Astro.props;

const toastId = `toast-${Math.random().toString(36).slice(2)}`;
---

<div
  id={toastId}
  class={`toast toast--${type}`}
  data-duration={duration}
>
  {type === "success" && "✅"}
  {type === "error"   && "❌"}
  {type === "info"    && "ℹ️"}
  {type === "warning" && "⚠️"}
  {" "}{message}
</div>

<style>
  .toast {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    padding: 0.85rem 1.4rem;
    border-radius: 10px;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 500;
    box-shadow: 0 4px 16px rgba(0,0,0,0.18);
    z-index: 9999;
    opacity: 1;
    transition: opacity 0.5s ease;
  }

  .toast--success { background-color: #22c55e; }
  .toast--error   { background-color: #ef4444; }
  .toast--info    { background-color: #3b82f6; }
  .toast--warning { background-color: #f59e0b; }

  .toast.hide { opacity: 0; pointer-events: none; }
</style>

<script define:vars={{ toastId, duration }}>
  const toast = document.getElementById(toastId);
  if (!toast) return;

  // apilar toasts verticalmente si hay más de uno
  const others = document.querySelectorAll(".toast:not(#" + toastId + ")");
  let offset = 1.5;
  others.forEach((t) => {
    offset += t.getBoundingClientRect().height / 16 + 0.5;
  });
  toast.style.bottom = offset + "rem";

  // auto-ocultar
  const timer = setTimeout(() => {
    toast.classList.add("hide");
  }, duration);

  // remover después de la transición
  toast.addEventListener("transitionend", () => {
    clearTimeout(timer);
    toast.remove();
    // limpiar query params cuando ya no queda ningún toast
    if (document.querySelectorAll(".toast").length === 0) {
      const url = new URL(window.location.href);
      url.searchParams.delete("success");
      url.searchParams.delete("updated");
      url.searchParams.delete("deleted");
      url.searchParams.delete("error");
      window.history.replaceState({}, "", url);
    }
  });
</script>