---
// src/presentation/layouts/DashboardLayout.astro
import "../styles/dashboard.css";
import Sidebar from "../components/dashboard/Sidebar.astro";
import Header from "../components/dashboard/Header.astro";

interface Props {
  title: string;
  role: string;
  userEmail: string | undefined;  // ← acepta undefined aquí
}

const { title, role, userEmail } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <div class="dashboard">
      <Sidebar role={role} />
      <div class="main">
        <Header email={userEmail ?? ""} />
        <main class="content">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>