---
import Layout from "../../presentation/layouts/Layout.astro";
import "../../presentation/styles/register.css";

const url = new URL(Astro.request.url);

const reason = url.searchParams.get("reason");
const type = url.searchParams.get("type");

let message = "";
let backUrl = "";

if (reason === "email") {

message =
"Este correo ya está registrado.";

}

if (reason === "duplicate") {

message =
type === "teacher"
?
"El número de profesor ya está registrado."
:
"La boleta ya está registrada.";

}

if (type === "teacher") {

backUrl = "/auth/register-teacher";

}
else {

backUrl = "/auth/register";

}

if (!message) {
message = "Ocurrio un problema al completar el registro.";
}

---

<Layout title="Error de registro">

<section class="auth">

<div class="card register-feedback-card">

<div class="feedback-icon error">
  !
</div>

<h1 class="feedback-title">
No se pudo completar el registro
</h1>

<p class="feedback-message">
{message}
</p>

<a
href={backUrl}
class="feedback-link"
>
Volver al registro
</a>

</div>

</section>

</Layout>
