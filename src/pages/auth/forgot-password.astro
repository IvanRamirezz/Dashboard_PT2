---
import AuthLayout from "../../presentation/layouts/AuthLayout.astro";
import InputField from "../../presentation/components/ui/InputField.astro";
import Alert from "../../presentation/components/ui/Alert.astro";

const message = Astro.url.searchParams.get("message");
const error   = Astro.url.searchParams.get("error");

const errorMessages: Record<string, string> = {
  link_expirado: "El enlace ha expirado. Solicita uno nuevo.",
  link_invalido: "El enlace debe abrirse en el mismo navegador donde lo solicitaste. Solicita uno nuevo.",
  "1":           "Ocurrió un error al enviar el correo. Intenta de nuevo.",
  default:       "Ocurrió un error. Intenta de nuevo.",
};

const errorMessage = error ? (errorMessages[error] ?? errorMessages.default) : null;
---

<AuthLayout title="Recuperar contraseña">
  <h1 class="title">Restablecer contraseña</h1>
  <p class="subtitle">Te enviaremos un link para restablecer tu contraseña</p>

  <form method="post" action="/api/auth/reset-password">
    {message && <Alert type="success" message="Revisa tu correo 📩 Abre el enlace en este mismo navegador." />}
    {errorMessage && <Alert type="error" message={errorMessage} />}

    <InputField
      label="Email"
      name="email"
      type="email"
      placeholder="correo@ejemplo.com"
    />

    <button class="btn">Enviar link</button>
  </form>
</AuthLayout>