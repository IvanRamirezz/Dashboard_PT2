---
import AuthLayout from "../../presentation/layouts/AuthLayout.astro";
import Alert from "../../presentation/components/ui/Alert.astro";
import PasswordField from "../../presentation/components/ui/PasswordField.astro";

const error   = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");

const errorMessages: Record<string, string> = {
  password_corto:      "La contraseña debe tener al menos 8 caracteres.",
  no_coinciden:        "Las contraseñas no coinciden.",
  misma_contrasena:    "La nueva contraseña debe ser diferente a la actual.",
  error_actualizacion: "No se pudo actualizar la contraseña. El enlace puede haber expirado.",
  default:             "Ocurrió un error. Solicita un nuevo enlace.",
};

const errorMessage = error ? (errorMessages[error] ?? errorMessages.default) : null;
---

<AuthLayout title="Nueva contraseña">
  <h1 class="title">
    {success ? "Contraseña actualizada" : "Nueva contraseña"}
  </h1>
  <p class="subtitle">
    {success
      ? "Tu contraseña se cambió correctamente. Ya puedes iniciar sesión."
      : "Escribe tu nueva contraseña. Mínimo 8 caracteres."
    }
  </p>

  <form method="post" action="/api/auth/update-password">
    {success      && <Alert type="success" message="Contraseña actualizada correctamente" />}
    {errorMessage && <Alert type="error"   message={errorMessage} />}

    {!success && (
      <>
        <PasswordField label="Nueva contraseña"      name="password"        />
        <PasswordField label="Confirmar contraseña"  name="passwordConfirm" />
        <button class="btn">Actualizar contraseña</button>
      </>
    )}

    {success && (
      <a href="/" class="btn">Ir al login</a>
    )}
  </form>
</AuthLayout>