---
import AuthLayout from "../../presentation/layouts/AuthLayout.astro";
import Alert from "../../presentation/components/ui/Alert.astro";
import PasswordField from "../../presentation/components/ui/PasswordField.astro";

const { url } = Astro;

const error = url.searchParams.get("error");
const success = url.searchParams.get("success");
---

<AuthLayout title="Nueva contraseña">

<h1 class="title">
  {success ? "Contraseña actualizada" : "Nueva contraseña"}
</h1>

<p class="subtitle">
  {success 
    ? "Tu contraseña se cambió correctamente. Ya puedes iniciar sesión."
    : "Escribe tu nueva contraseña."
  }
</p>

<form method="post" action="/api/auth/update-password">

  {success && <Alert type="success" message="Contraseña actualizada correctamente" />}
  {error && <Alert type="error" message="Error al actualizar contraseña" />}

  {!success && (
    <>
      <PasswordField label="Nueva contraseña" name="password" />
      <button class="btn">Actualizar contraseña</button>
    </>
  )}

</form>

<script>
  const hash = window.location.hash;
  if (hash) {
    const params = new URLSearchParams(hash.substring(1));
    const accessToken = params.get("access_token");
    const refreshToken = params.get("refresh_token");
    const type = params.get("type");

    if (accessToken && type === "recovery") {
      document.cookie = `sb-access-token=${accessToken}; path=/; samesite=lax`;
      document.cookie = `sb-refresh-token=${refreshToken}; path=/; samesite=lax`;
      window.history.replaceState(null, "", window.location.pathname);
    }
  }
</script>

</AuthLayout>