---
import DashboardLayout from "../../../presentation/layouts/DashboardLayout.astro";
import TeacherSection  from "../../../presentation/components/profesor/TeacherSection.astro";
import GrupoSelector   from "../../../presentation/components/profesor/GrupoSelector.astro";
import Toast           from "../../../presentation/components/ui/Toast.astro";

import { getGroupsByTeacher } from "../../../business/profesor/grupoService";

import "../../../presentation/styles/profesor.css";

const { user, roleData } = Astro.locals;

const grupos = await getGroupsByTeacher(roleData.usuarioId);

const grupoId    = Number(Astro.url.searchParams.get("grupo")) || grupos?.[0]?.grupo_id;
const grupoActual = grupos.find(g => g.grupo_id == grupoId);

type ToastType = "success" | "error" | "warning" | "info";
type ToastKey  = "alta" | "baja" | "alta_existe" | "baja_error" | "reactivado";

const toastMap: Record<ToastKey, { message: string; type: ToastType }> = {
  alta:        { message: "Grupo dado de alta exitosamente",              type: "success" },
  baja:        { message: "Grupo dado de baja exitosamente",              type: "warning" },
  alta_existe: { message: "Este grupo ya existe",                         type: "error"   },
  baja_error:  { message: "El grupo no existe o ya está dado de baja",    type: "error"   },
  reactivado:  { message: "Grupo reactivado correctamente",               type: "info"    },
};

const successKey = Astro.url.searchParams.get("success") as ToastKey | null;
const toast      = successKey ? toastMap[successKey] : undefined;
---

<DashboardLayout title="Gestión del grupo" role="profesor" userEmail={user.email}>

  <TeacherSection
    title="Gestión del grupo"
    description="Puedes crear nuevos grupos, seleccionar uno existente para consultar su código de acceso o darlo de baja."
  >

    <form method="POST" action="/api/profesor/gestionar-grupos">

      <label class="grupo-label">Grupo</label>

      <div class="grupo-actions">
        <input
          type="text"
          name="grupo"
          placeholder="Ej. 3IM14"
          required
          style="text-transform: uppercase;"
          oninput="this.value = this.value.toUpperCase()"
        />
        <button name="action" value="alta" class="btn-primary">Dar de alta</button>
        <button name="action" value="baja" class="btn-danger">Dar de baja</button>
      </div>

    </form>

    <div class="grupo-info">
      <div>
        <label>Selecciona el grupo:</label>
        <GrupoSelector grupos={grupos} grupoId={grupoId} />
      </div>
      <div>
        <label>Código del grupo:</label>
        <div class="codigo-box">{grupoActual?.codigo_acceso || "----"}</div>
      </div>
    </div>

  </TeacherSection>

  {toast && <Toast message={toast.message} type={toast.type} />}

</DashboardLayout>