---
import DashboardLayout from "../../../presentation/layouts/DashboardLayout.astro";
import TeacherSection from "../../../presentation/components/profesor/TeacherSection.astro";
import Toast from "../../../presentation/components/ui/Toast.astro";

import { getAssignmentFormData } from "../../../business/profesor/asignacionService";

import "../../../presentation/styles/profesor.css";

const { user, roleData } = Astro.locals;

const { practicas, grupos } = await getAssignmentFormData(roleData.usuarioId);

const toastMap: Record<string, { message: string; type: "success" | "error" | "warning" | "info" }> = {
  asignacion: { message: "Práctica asignada exitosamente", type: "success" },
  error:      { message: "Error al asignar la práctica. Intenta de nuevo.", type: "error" },
};

const successKey = Astro.url.searchParams.get("success") ?? Astro.url.searchParams.get("error") ? "error" : "";
const toast      = toastMap[Astro.url.searchParams.get("success") ?? ""] 
                ?? (Astro.url.searchParams.get("error") ? toastMap["error"] : undefined);

const hoy = new Date().toISOString().split("T")[0];
---

<DashboardLayout title="Asignar práctica" role="profesor" userEmail={user.email}>

  <TeacherSection
    title="Asignar práctica"
    description="Asigna prácticas a tus grupos para que los alumnos puedan realizarlas en el entorno de FiberLab VR."
  >

    <form method="POST" action="/api/profesor/asignar" class="teacher-form-box">

      <label class="teacher-label">Selecciona la práctica a realizar</label>
      <select name="practica_id" class="teacher-select" required>
        <option value="">Seleccionar práctica</option>
        {practicas.map(p => (
          <option value={p.practica_id}>{p.titulo}</option>
        ))}
      </select>

      <label class="teacher-label">Selecciona el grupo al que asignar la práctica</label>
      <select name="grupo_id" class="teacher-select" required>
        <option value="">Seleccionar grupo</option>
        {grupos.map(g => (
          <option value={g.grupo_id}>{g.nombre}</option>
        ))}
      </select>

      <label class="teacher-label">Fecha límite de entrega</label>
      <input
        type="date"
        name="fecha_fin"
        class="teacher-select"
        min={hoy}
        required
      />

      <div class="teacher-actions">
        <button class="teacher-btn" type="submit">Asignar</button>
      </div>

    </form>

  </TeacherSection>

  {toast && <Toast message={toast.message} type={toast.type} />}

</DashboardLayout>