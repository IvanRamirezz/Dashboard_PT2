---
// src/pages/dashboard/admin/alumnos.astro
import DashboardLayout from "../../../presentation/layouts/DashboardLayout.astro";
import UserEditor from "../../../presentation/components/admin/UserEditor.astro";
import Toast from "../../../presentation/components/ui/Toast.astro";
import {
  getStudentByBoleta,
  getCiclosEscolares,
  getGruposByCiclo,
  getStudentListAdmin,
  PAGE_SIZE,
} from "../../../business/admin/studentService";

const { user } = Astro.locals;

const boleta  = Astro.url.searchParams.get("boleta")  ?? undefined;
const updated = Astro.url.searchParams.get("updated") ?? undefined;
const deleted = Astro.url.searchParams.get("deleted") ?? undefined;
const error   = Astro.url.searchParams.get("error")   ?? undefined;

const editMode = !!boleta;

// List mode state
let ciclos: string[]                             = [];
let grupos: { grupo_id: number; nombre: string }[] = [];
let alumnos: any[]                               = [];
let total      = 0;
let totalPages = 0;
let selectedCiclo = "";
let selectedGrupo = 0;
let grupoNombre   = "";

const cicloParam  = Astro.url.searchParams.get("ciclo")  ?? undefined;
const grupoParam  = Astro.url.searchParams.get("grupo")  ?? undefined;
const search      = Astro.url.searchParams.get("search") ?? undefined;
const page        = Math.max(1, Number(Astro.url.searchParams.get("page") ?? "1"));

let student = null;

if (editMode) {
  student = await getStudentByBoleta(boleta!);
} else {
  ciclos = await getCiclosEscolares();
  selectedCiclo = cicloParam ?? ciclos[0] ?? "";

  if (selectedCiclo) {
    grupos = await getGruposByCiclo(selectedCiclo);
    selectedGrupo = grupoParam ? Number(grupoParam) : (grupos[0]?.grupo_id ?? 0);
    grupoNombre   = grupos.find((g) => g.grupo_id === selectedGrupo)?.nombre ?? "";
  }

  if (selectedGrupo) {
    const result = await getStudentListAdmin(selectedGrupo, page, search);
    alumnos    = result.data;
    total      = result.total;
    totalPages = Math.ceil(total / PAGE_SIZE);
  }
}

// Build pagination page numbers (with ellipsis)
function pageNumbers(cur: number, tot: number): (number | "…")[] {
  if (tot <= 5) return Array.from({ length: tot }, (_, i) => i + 1);
  if (cur <= 3) return [1, 2, 3, "…", tot];
  if (cur >= tot - 2) return [1, "…", tot - 2, tot - 1, tot];
  return [1, "…", cur - 1, cur, cur + 1, "…", tot];
}

const pages = totalPages > 1 ? pageNumbers(page, totalPages) : [];

function listUrl(overrides: Record<string, string | number | undefined>) {
  const p = new URLSearchParams();
  const vals = { ciclo: selectedCiclo, grupo: selectedGrupo, page, search, ...overrides };
  for (const [k, v] of Object.entries(vals)) {
    if (v !== undefined && v !== "" && v !== 0) p.set(k, String(v));
  }
  return `/dashboard/admin/alumnos?${p.toString()}`;
}
---

<DashboardLayout
  title="Gestión de alumnos"
  role="admin"
  userEmail={user.email ?? ""}
>

  {editMode ? (
    <div>
      <a href="/dashboard/admin/alumnos" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Volver a la lista
      </a>

      <UserEditor
        title="Editar alumno"
        description="Actualiza los datos del alumno o da de baja su registro en el sistema."
        searchName="boleta"
        searchLabel="Número de boleta"
        idField="alumno_id"
        identifierField="boleta"
        identifierValue={boleta}
        updateAction="/api/admin/update-student"
        deleteAction="/api/admin/delete-student"
        user={student}
        updated={updated}
        hideSearch={true}
      />

      {deleted && <Toast message="Alumno dado de baja correctamente." type="warning" />}
      {error === "campos_vacios" && <Toast message="Todos los campos son requeridos." type="error" />}
      {error === "actualizacion" && <Toast message="Error al actualizar. Intenta de nuevo." type="error" />}
    </div>
  ) : (
    <div class="module">
      <h2>Gestión de alumno</h2>
      <p class="module-description">Selecciona un grupo para ver la lista de alumnos registrados.</p>

      <!-- Filtros -->
      <form method="GET" class="filters-form">
        <div class="filters-row">

          <div class="filter-field">
            <label class="filter-label">Período escolar</label>
            <select name="ciclo" class="filter-select" onchange="this.form.submit()">
              {ciclos.map((c) => (
                <option value={c} selected={c === selectedCiclo}>{c}</option>
              ))}
            </select>
          </div>

          <div class="filter-field">
            <label class="filter-label">Grupo</label>
            <select name="grupo" class="filter-select" onchange="this.form.submit()">
              {grupos.map((g) => (
                <option value={g.grupo_id} selected={g.grupo_id === selectedGrupo}>
                  {g.nombre}
                </option>
              ))}
            </select>
          </div>

          <div class="filter-field filter-field--grow">
            <label class="filter-label">Número de boleta</label>
            <div class="filter-search-row">
              <input
                name="search"
                class="filter-input"
                placeholder="Buscar por número de boleta"
                value={search ?? ""}
              />
              <button type="submit" class="btn primary">Buscar</button>
            </div>
          </div>

        </div>
      </form>

      <!-- Tabla -->
      {grupoNombre && (
        <div>
          <div class="section-header">
            <span class="section-title">Alumnos del grupo {grupoNombre}</span>
            <span class="badge-total">Total: {total}</span>
          </div>

          <table class="table">
            <thead>
              <tr>
                <th>Número de boleta</th>
                <th>Nombre</th>
                <th>Apellido paterno</th>
                <th>Apellido materno</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              {alumnos.length === 0 ? (
                <tr>
                  <td colspan="5" class="empty-row">
                    No hay alumnos en este grupo.
                  </td>
                </tr>
              ) : (
                alumnos.map((a) => (
                  <tr>
                    <td>{a.boleta}</td>
                    <td>{a.usuarios?.nombre}</td>
                    <td>{a.usuarios?.apellido_paterno}</td>
                    <td>{a.usuarios?.apellido_materno}</td>
                    <td>
                      <a href={`/dashboard/admin/alumnos?boleta=${a.boleta}`} class="btn-edit">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        Editar
                      </a>
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>

          <!-- Paginación -->
          {totalPages > 1 && (
            <div class="pagination">
              <a
                href={listUrl({ page: page - 1 })}
                class:list={["page-btn", { "page-btn--disabled": page === 1 }]}
                aria-disabled={page === 1}
              >Anterior</a>

              {pages.map((p) =>
                p === "…" ? (
                  <span class="page-ellipsis">…</span>
                ) : (
                  <a
                    href={listUrl({ page: p })}
                    class:list={["page-btn", { "page-btn--active": p === page }]}
                  >
                    {p}
                  </a>
                )
              )}

              <a
                href={listUrl({ page: page + 1 })}
                class:list={["page-btn", { "page-btn--disabled": page === totalPages }]}
                aria-disabled={page === totalPages}
              >Siguiente</a>
            </div>
          )}

          <!-- Info tip -->
          <div class="info-tip">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            Selecciona un alumno y da clic en "Editar" para modificar su información.
          </div>
        </div>
      )}

      {!grupoNombre && ciclos.length === 0 && (
        <p class="module-description">No hay grupos activos registrados en el sistema.</p>
      )}
    </div>
  )}

</DashboardLayout>
