---
// src/pages/dashboard/admin/alumnos.astro
import DashboardLayout from "../../../presentation/layouts/DashboardLayout.astro";
import UserEditor from "../../../presentation/components/admin/UserEditor.astro";
import Toast from "../../../presentation/components/ui/Toast.astro";
import { getValidatedSession } from "../../../business/auth/sessionService";
import { getUserRole } from "../../../business/auth/userRoleService";
import { getStudentByBoleta } from "../../../business/admin/studentService";

const user = await getValidatedSession(Astro.cookies);
if (!user) return Astro.redirect("/");

const roleData = await getUserRole(user.id);
if (roleData?.role !== "admin") return Astro.redirect("/");

const boleta  = Astro.url.searchParams.get("boleta")  ?? undefined;
const updated = Astro.url.searchParams.get("updated")  ?? undefined;
const deleted = Astro.url.searchParams.get("deleted")  ?? undefined;

const student = boleta ? await getStudentByBoleta(boleta) : null;
---

<DashboardLayout
  title="Gestión de alumno"
  role="admin"
  userEmail={user.email ?? ""}
>
  <UserEditor
    title="Gestión de alumno"
    description="Gestiona la información de los alumnos registrados. Busca por boleta, actualiza sus datos o da de baja su registro en el sistema."
    searchName="boleta"
    searchLabel="Número de boleta"
    idField="alumno_id"
    identifierField="boleta"
    identifierValue={boleta}
    updateAction="/api/admin/update-student"
    deleteAction="/api/admin/delete-student"
    user={student}
    updated={updated}
  />

  {deleted && (
    <Toast message="Alumno dado de baja correctamente." type="warning" />
  )}
</DashboardLayout>