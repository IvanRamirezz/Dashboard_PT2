---
// src/pages/dashboard/admin/profesores.astro
import DashboardLayout from "../../../presentation/layouts/DashboardLayout.astro";
import UserEditor from "../../../presentation/components/admin/UserEditor.astro";
import { getValidatedSession } from "../../../business/auth/sessionService";
import { getUserRole } from "../../../business/auth/userRoleService";
import { getTeacherByMatricula } from "../../../business/admin/teacherService";

const user = await getValidatedSession(Astro.cookies);
if (!user) return Astro.redirect("/");

const roleData = await getUserRole(user.id);
if (roleData?.role !== "admin") return Astro.redirect("/");

const matricula = Astro.url.searchParams.get("matricula") ?? undefined;
const updated   = Astro.url.searchParams.get("updated")   ?? undefined;

const teacher = matricula ? await getTeacherByMatricula(matricula) : null;
---

<DashboardLayout
  title="Gestión de profesor"
  role="admin"
  userEmail={user.email ?? ""}
>
  <UserEditor
    title="Gestión de profesor"
    description="Gestiona la información de los profesores registrados. Busca por matrícula, actualiza sus datos o da de baja su registro en el sistema."
    searchName="matricula"
    searchLabel="Matrícula"
    idField="profesor_id"
    identifierField="matricula_trabajador"
    identifierValue={matricula}
    updateAction="/api/admin/update-teacher"
    deleteAction="/api/admin/delete-teacher"
    user={teacher}
    updated={updated}
  />
</DashboardLayout>