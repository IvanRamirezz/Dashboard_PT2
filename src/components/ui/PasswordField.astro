---
import ojo from "../../assets/ojo.png";
import ojoOcultar from "../../assets/ojo-ocultar.png";

interface Props {
  label?: string;
  name?: string;
  placeholder?: string;
  required?: boolean;
}

const {
  label = "Contraseña",
  name = "password",
  placeholder = "••••••••",
  required = true
} = Astro.props;

const inputId = `password-${Math.random().toString(36).slice(2)}`;
---

<div class="field">

  <label for={inputId}>
    {label}
  </label>

  <div class="password-container">

    <input
      id={inputId}
      name={name}
      type="password"
      placeholder={placeholder}
      required={required}
    />

    <button
      type="button"
      class="toggle-password"
      data-target={inputId}
    >

      <img
        src={ojo.src}
        alt="Mostrar contraseña"
      />

    </button>

  </div>

</div>


<script
  data-eye={ojo.src}
  data-eye-off={ojoOcultar.src}
>

const eye = document.currentScript.dataset.eye;
const eyeOff = document.currentScript.dataset.eyeOff;

document.querySelectorAll(".toggle-password").forEach(btn => {

  btn.addEventListener("click", () => {

    const targetId = btn.getAttribute("data-target");

    const input = document.getElementById(targetId);

    const icon = btn.querySelector("img");

    if (!input || !icon) return;

    const isHidden = input.type === "password";

    input.type = isHidden ? "text" : "password";

    icon.src = isHidden ? eyeOff : eye;

  });

});

</script>